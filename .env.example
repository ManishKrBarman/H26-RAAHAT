# ═══════════════════════════════════════════════════════════
# Raahat — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and modify values as needed:
#   cp .env.example .env
#
# ⚠️  NEVER commit .env to git — it may contain secrets.
#     Only .env.example is committed (with safe placeholder values).
#
# Then run:
#   docker compose up -d --build
# ═══════════════════════════════════════════════════════════


# ── Ports (host-side) ─────────────────────────────────────
FRONTEND_PORT=3000
BACKEND_PORT=3001
MONGO_PORT=27017
MODEL_PORT=8000


# ── MongoDB ───────────────────────────────────────────────
# Connection string used by the backend.
# For Docker:   mongodb://mongodb:27017/raahat   (service name)
# For local:    mongodb://127.0.0.1:27017/raahat
MONGODB_URI=mongodb://127.0.0.1:27017/raahat

# Database name (used by MongoDB init)
MONGO_DB_NAME=raahat

# Uncomment and set these for authenticated MongoDB (production)
# MONGO_INITDB_ROOT_USERNAME=admin
# MONGO_INITDB_ROOT_PASSWORD=changeme_strong_password


# ── Backend API ───────────────────────────────────────────
# Port the backend listens on INSIDE the container
BACKEND_INTERNAL_PORT=3000

# Node environment
NODE_ENV=development


# ── Frontend API URL ──────────────────────────────────────
# This is the URL the BROWSER uses to reach the backend.
# NOTE: Vite reads .env from the frontend/ directory, not project root.
#       Set this in frontend/.env for local dev.
# For local dev:     http://localhost:3000  (backend's actual port)
# For local Docker:  http://localhost:3001  (mapped host port)
# For production:    https://api.yourdomain.com
VITE_API_BASE_URL=http://localhost:3000


# ── Model Server (Python FastAPI + YOLOv8) ────────────────
# Full URL to the /predict endpoint
# For Docker:   http://model:8000/predict   (service name)
# For local:    http://localhost:8000/predict
MODEL_API_URL=http://localhost:8000/predict

# Model prediction timeout in milliseconds (default: 4 minutes)
MODEL_TIMEOUT=240000

# Backend URL as seen by the model server (for downloading videos)
# For Docker:   http://backend:3000
# For local:    http://localhost:3000
MODEL_BACKEND_URL=http://localhost:3000

# Path to YOLOv8 model weights inside the container
MODEL_PATH=best2.pt

# Path to audio model weights inside the container
AUDIO_MODEL_PATH=raahat_audio_model.h5

# Port the model server listens on
MODEL_INTERNAL_PORT=8000


# ── CORS (optional) ──────────────────────────────────────
# Allowed origins for CORS. Comma-separated.
# Leave empty to allow all origins (development only).
# CORS_ORIGIN=http://localhost:3000,http://localhost:3001


# ── ESP32 (for reference — these go in the .ino file) ────
# WiFi SSID and password for the ESP32 controller.
# These are NOT used by Docker — they are for reference only.
# ESP32_WIFI_SSID=your_wifi_ssid
# ESP32_WIFI_PASSWORD=your_wifi_password
# ESP32_SERVER_IP=192.168.1.x
# ESP32_SERVER_PORT=3001
