# ═══════════════════════════════════════════════
# Raahat — Docker Environment Variables
# ═══════════════════════════════════════════════
# Copy this file to .env and modify as needed:
#   cp .env.example .env
#
# Then run:
#   docker compose up -d --build

# ── Ports (host:container) ──
FRONTEND_PORT=3000
BACKEND_PORT=3001
MONGO_PORT=27017

# ── API URL (baked into frontend JS at build time) ──
# This is the URL the BROWSER uses to reach the backend.
# For local Docker:  http://localhost:3001
# For production:    https://api.yourdomain.com
VITE_API_BASE_URL=http://localhost:3001
